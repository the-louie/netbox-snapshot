# NetBox test stack environment, "source" side.
# Not production grade. The SECRET_KEY and admin token are fixed so
# the seeder and the integration tests can use predictable values.

ALLOWED_HOSTS=*
CORS_ORIGINS_ALLOWED=*
DB_HOST=postgres
DB_NAME=netbox
DB_USER=netbox
DB_PASSWORD=netbox
REDIS_HOST=redis
REDIS_PASSWORD=netbox
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PASSWORD=netbox

# 50-char secret key, fine for tests only. NetBox refuses to start
# when this string is shorter than 50 characters.
SECRET_KEY=source-test-secret-key-aaaaaaaaaaaaaaaaaaaaaaaaaaa

SKIP_STARTUP_SCRIPTS=true
SKIP_SUPERUSER=false
SUPERUSER_NAME=admin
SUPERUSER_EMAIL=admin@example.invalid
SUPERUSER_PASSWORD=admin
SUPERUSER_API_TOKEN=0123456789abcdef0123456789abcdef01234567

# netbox-docker refuses to seed `SUPERUSER_API_TOKEN` unless
# `API_TOKEN_PEPPERS` is also set; the container log emits
# "No API token was created as API_TOKEN_PEPPERS is not set"
# and then every authenticated call to the API answers 403.
# A fixed value is fine for tests; rotate in production.
API_TOKEN_PEPPERS=source-test-pepper-aaaaaaaaaaaaaaaa
