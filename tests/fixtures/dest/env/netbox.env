# NetBox test stack environment, "destination" side.
# Different SECRET_KEY and admin token from the source stack so the
# password-hash portability friction (docs/frictions/07) is
# exercised on every round-trip integration run.

ALLOWED_HOSTS=*
CORS_ORIGINS_ALLOWED=*
DB_HOST=postgres
DB_NAME=netbox
DB_USER=netbox
DB_PASSWORD=netbox
REDIS_HOST=redis
REDIS_PASSWORD=netbox
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PASSWORD=netbox

# Distinct 50-char secret key, fine for tests only.
SECRET_KEY=dest-test-secret-key-bbbbbbbbbbbbbbbbbbbbbbbbbbbb

SKIP_STARTUP_SCRIPTS=true
SKIP_SUPERUSER=false
SUPERUSER_NAME=admin
SUPERUSER_EMAIL=admin@example.invalid
SUPERUSER_PASSWORD=admin
SUPERUSER_API_TOKEN=abcdef0123456789abcdef0123456789abcdef01
