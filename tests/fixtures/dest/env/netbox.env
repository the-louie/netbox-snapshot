# NetBox test stack environment, "destination" side.
# Different SECRET_KEY and admin token from the source stack so the
# password-hash portability friction (docs/frictions/07) is
# exercised on every round-trip integration run.

ALLOWED_HOSTS=*
CORS_ORIGINS_ALLOWED=*
DB_HOST=postgres
DB_NAME=netbox
DB_USER=netbox
DB_PASSWORD=netbox
REDIS_HOST=redis
REDIS_PASSWORD=netbox
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PASSWORD=netbox

# Distinct 50-char secret key, fine for tests only. NetBox refuses
# to start when this string is shorter than 50 characters.
SECRET_KEY=dest-test-secret-key-bbbbbbbbbbbbbbbbbbbbbbbbbbbbb

SKIP_STARTUP_SCRIPTS=true
SKIP_SUPERUSER=false
SUPERUSER_NAME=admin
SUPERUSER_EMAIL=admin@example.invalid
SUPERUSER_PASSWORD=admin
SUPERUSER_API_TOKEN=abcdef0123456789abcdef0123456789abcdef01

# netbox-docker creates v2 tokens. The pepper plus a per superuser
# key combine with the token to produce the stored hash; without
# both, `docker/super_user.py` logs "No API token was created" and
# every request to /api/status/ with the token then answers 403.
# The configuration.py upstream reads the env var as
# `API_TOKEN_PEPPER_1` (indexed), not the plural `API_TOKEN_PEPPERS`.
# Fixed values are fine for tests; rotate in production.
API_TOKEN_PEPPER_1=dest-test-pepper-bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
SUPERUSER_API_KEY=dest-test-api-key-bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
