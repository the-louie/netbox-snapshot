!
!
! This must be last! 2950 will crash if changing the uplink too early
!
interface Vlan1
 no ip address
 no ip route-cache
 shutdown
!
interface Vlan 600
 description Management VLAN
 ip address {{ ip_address }} {{ mask }}
 no ip route-cache
!
interface range FastEthernet0/1 - 24
  no shut
!
