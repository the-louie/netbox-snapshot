{# ============================================================================
   Per-dist Junos config — DYNAMIC content only.
   Operator-maintained; the renderer (netbox2junos.py) populates the
   variables below from NetBox.

   Context variables expected:
     dist_name             str         e.g. "D-THE-FORGE-SW"
     mgmt_vlan_name        str         e.g. "THE_FORGE_ACCESS-MGMT"   from NetBox VLAN.name
     loopback_v4           str         e.g. "172.16.255.4/32"  (never None, renderer raises)
     mgmt_v4               str | None  e.g. "172.16.1.1/24"
     ospf                  dict[int → {description, v4, v6}]
                                       keys 1100, 1101, 1200, 1201
     participants          list of {vid, ipv4, ipv6, description, vlan_name}
     cabled_ports          list of {port_num, description, vid}
     dhcp4_servers         list[str]   IPv4 DHCP relay targets        (required, non empty)
     dhcp6_servers         list[str]   IPv6 DHCP relay targets        (may be empty)
     ipv6_ra_dns           list[str]   IPv6 DNS to advertise in RA    (may be empty)
     netbox_host           str         for the header comment
   ============================================================================ #}
# ----------------------------------------------------------------
# Generated by netbox2junos.py — do not hand-edit.
# Source of truth: NetBox at {{ netbox_host }}
# Device:  {{ dist_name }}
#
# Per-dist DYNAMIC content only. Concatenate with the hand-maintained
# static platform template (ACCESS_FILTERS, ROUTING-POLICIES,
# LOAD-POLICIES, QOS, FORWARDING, PROTOCOLS, SNMP, DIST-UPLINKS,
# L2-TRANSIT, plus SYSTEM minus host-name) before loading on the device.
#
# netbox2junos.py - Louie 2026
# ----------------------------------------------------------------

# ---- SYSTEM (host-name only) ----
set groups SYSTEM system host-name {{ dist_name }}

# ---- LOOPBACKS ----
set groups LOOPBACKS interfaces lo0 unit 0 family inet address {{ loopback_v4 }}
set groups LOOPBACKS interfaces lo0 unit 0 family inet filter input FW-IN-RE-V4
set groups LOOPBACKS interfaces lo0 unit 0 family inet6 filter input FW-IN-RE-V6

set apply-groups LOOPBACKS

# ---- OSPF-DEFAULT IRB addresses ----
{% for vid in [1100, 1200] -%}
set groups OSPF-DEFAULT interfaces irb unit {{ vid }} description "{{ ospf[vid].description }} (VLAN: {{ vid }})"
{% if ospf[vid].v4 -%}
set groups OSPF-DEFAULT interfaces irb unit {{ vid }} family inet address {{ ospf[vid].v4 }}
{% endif -%}
{% if ospf[vid].v6 -%}
set groups OSPF-DEFAULT interfaces irb unit {{ vid }} family inet6 address {{ ospf[vid].v6 }}
{% endif %}
{% endfor %}
# ---- OSPF-INTERNET IRB addresses ----
{% for vid in [1101, 1201] -%}
set groups OSPF-INTERNET interfaces irb unit {{ vid }} description "{{ ospf[vid].description }} (VLAN: {{ vid }})"
{% if ospf[vid].v4 -%}
set groups OSPF-INTERNET interfaces irb unit {{ vid }} family inet address {{ ospf[vid].v4 }}
{% endif -%}
{% if ospf[vid].v6 -%}
set groups OSPF-INTERNET interfaces irb unit {{ vid }} family inet6 address {{ ospf[vid].v6 }}
{% endif %}
{% endfor %}
# ---- VLANS ----
set groups VLANS vlans {{ mgmt_vlan_name }} vlan-id 600
{% for p in participants -%}
set groups VLANS vlans {{ p.vlan_name }} vlan-id {{ p.vid }}
{% endfor %}
set apply-groups VLANS

# ---- DOWNLINKS — dhcp-relay (default RI, for irb.600) ----
set groups DOWNLINKS forwarding-options dhcp-relay overrides trust-option-82
set groups DOWNLINKS forwarding-options dhcp-relay overrides no-unicast-replies
set groups DOWNLINKS forwarding-options dhcp-relay relay-option-82 circuit-id use-interface-description device
set groups DOWNLINKS forwarding-options dhcp-relay forward-only
set groups DOWNLINKS forwarding-options dhcp-relay group IPV4-DOWNLINK active-server-group IPV4-DOWNLINK
{% for ip in dhcp4_servers -%}
set groups DOWNLINKS forwarding-options dhcp-relay server-group IPV4-DOWNLINK {{ ip }}
{% endfor %}
# ---- DOWNLINKS — dhcp-relay (internet RI, for participant IRBs) ----
set groups DOWNLINKS routing-instances internet forwarding-options dhcp-relay overrides trust-option-82
set groups DOWNLINKS routing-instances internet forwarding-options dhcp-relay overrides no-unicast-replies
set groups DOWNLINKS routing-instances internet forwarding-options dhcp-relay forward-only
set groups DOWNLINKS routing-instances internet forwarding-options dhcp-relay relay-option-82 circuit-id use-interface-description device
set groups DOWNLINKS routing-instances internet forwarding-options dhcp-relay group IPV4-DOWNLINK active-server-group IPV4-DOWNLINK
{% for ip in dhcp4_servers -%}
set groups DOWNLINKS routing-instances internet forwarding-options dhcp-relay server-group IPV4-DOWNLINK {{ ip }}
{% endfor -%}
{% if dhcp6_servers -%}
set groups DOWNLINKS routing-instances internet forwarding-options dhcp-relay dhcpv6 forward-only
set groups DOWNLINKS routing-instances internet forwarding-options dhcp-relay dhcpv6 group IPV6-DOWNLINK active-server-group IPV6-DOWNLINK
{% for ip in dhcp6_servers -%}
set groups DOWNLINKS routing-instances internet forwarding-options dhcp-relay dhcpv6 server-group IPV6-DOWNLINK {{ ip }}
{% endfor -%}
{% endif %}
# ---- DOWNLINKS — irb.600 (mgmt SVI) ----
set groups DOWNLINKS interfaces irb unit 600 description {{ mgmt_vlan_name }}
{% if mgmt_v4 -%}
set groups DOWNLINKS interfaces irb unit 600 family inet address {{ mgmt_v4 }}
{% endif %}
set groups DOWNLINKS forwarding-options dhcp-relay group IPV4-DOWNLINK interface irb.600
set groups DOWNLINKS vlans {{ mgmt_vlan_name }} l3-interface irb.600

# ---- DOWNLINKS — participant IRBs ----
{% for p in participants %}
# irb.{{ p.vid }} ({{ p.description }})
set groups DOWNLINKS interfaces irb unit {{ p.vid }} description {{ p.description }}
set groups DOWNLINKS interfaces irb unit {{ p.vid }} family inet address {{ p.ipv4 }}
{% if p.ipv6 -%}
set groups DOWNLINKS interfaces irb unit {{ p.vid }} family inet6 address {{ p.ipv6 }}

set groups DOWNLINKS protocols router-advertisement interface irb.{{ p.vid }} managed-configuration
set groups DOWNLINKS protocols router-advertisement interface irb.{{ p.vid }} other-stateful-configuration
{% for dns in ipv6_ra_dns -%}
set groups DOWNLINKS protocols router-advertisement interface irb.{{ p.vid }} dns-server-address {{ dns }}
{% endfor -%}
set groups DOWNLINKS protocols router-advertisement interface irb.{{ p.vid }} prefix {{ p.ipv6 }}
{% endif %}
set groups DOWNLINKS routing-instances internet forwarding-options dhcp-relay group IPV4-DOWNLINK interface irb.{{ p.vid }}
{% if p.ipv6 and dhcp6_servers -%}
set groups DOWNLINKS routing-instances internet forwarding-options dhcp-relay dhcpv6 group IPV6-DOWNLINK interface irb.{{ p.vid }}
{% endif -%}
set groups DOWNLINKS routing-instances internet interface irb.{{ p.vid }}
set groups DOWNLINKS vlans {{ p.vlan_name }} l3-interface irb.{{ p.vid }}
{% endfor %}
set apply-groups DOWNLINKS

# ---- PHYSICAL-INTERFACES ----
{% for p in cabled_ports %}
set groups PHYSICAL-INTERFACES interfaces ge-0/0/{{ p.port_num }} description "{{ p.description }}"
set groups PHYSICAL-INTERFACES interfaces ge-0/0/{{ p.port_num }} unit 0 family ethernet-switching interface-mode trunk
set groups PHYSICAL-INTERFACES interfaces ge-0/0/{{ p.port_num }} native-vlan-id {{ p.vid }}
set groups PHYSICAL-INTERFACES interfaces ge-0/0/{{ p.port_num }} unit 0 family ethernet-switching vlan members {{ p.vid }}
set groups PHYSICAL-INTERFACES interfaces ge-0/0/{{ p.port_num }} unit 0 family ethernet-switching vlan members 600
set groups PHYSICAL-INTERFACES interfaces ge-0/0/{{ p.port_num }} unit 0 family ethernet-switching storm-control default
{% endfor %}
set apply-groups PHYSICAL-INTERFACES
